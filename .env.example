NEXT_PUBLIC_SUPABASE_URL=https://jubntyastnabvbtylfba.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Prisma / Database
# Transaction pooler (IPv4-compatible, for app queries)
# DATABASE_URL="postgresql://postgres.jubntyastnabvbtylfba:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler (for Prisma migrations)
# DIRECT_URL="postgresql://postgres.jubntyastnabvbtylfba:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Server-side secrets
# SUPABASE_SECRET_KEY=sb_secret_...

# Gemini (for embeddings)
# GEMINI_API_KEY=your-key-here

# Anthropic Claude (for LinkedIn post generation — temporary while Gemini billing activates)
# ANTHROPIC_API_KEY=sk-ant-...

# Zernio — LinkedIn posting API
# Get API key + connect your LinkedIn at https://zernio.com
# ZERNIO_API_KEY=your_zernio_api_key
# ZERNIO_LINKEDIN_ACCOUNT_ID=your_connected_linkedin_account_id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
