generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model NewsletterSource {
  id              String    @id @default(uuid())
  name            String
  type            String    // "rss" | "manual"
  url             String?
  lastFetchedAt   DateTime? @map("last_fetched_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  articles        Article[]

  @@map("newsletter_sources")
}

model Article {
  id              String             @id @default(uuid())
  sourceId        String?            @map("source_id")
  source          NewsletterSource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title           String
  url             String             @unique
  content         String             @db.Text
  excerpt         String?            @db.Text
  author          String?
  publishedAt     DateTime?          @map("published_at")
  contentHash     String?            @map("content_hash") @unique
  canonicalUrl    String?            @map("canonical_url")
  siteName        String?            @map("site_name")
  charCount       Int?               @map("char_count")
  extractionMethod String?           @map("extraction_method")
  createdAt       DateTime           @default(now()) @map("created_at")
  dailyIdeas      DailyIdea[]
  chunks          ArticleChunk[]

  @@map("articles")
}

model ArticleChunk {
  id              String    @id @default(uuid())
  articleId       String    @map("article_id")
  article         Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  chunkIndex      Int       @map("chunk_index")
  text            String    @db.Text
  charStart       Int       @map("char_start")
  charEnd         Int       @map("char_end")
  embedding       Unsupported("vector(768)")?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([articleId, chunkIndex])
  @@map("article_chunks")
}

model StyleProfile {
  id              String    @id @default(uuid())
  name            String
  promptText      String    @map("prompt_text")
  isActive        Boolean   @default(false) @map("is_active")
  isClonedVoice   Boolean   @default(false) @map("is_cloned_voice")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("style_profiles")
}

model LinkedInProfile {
  id              String    @id @default(uuid())
  profileUrl      String    @unique @map("profile_url")
  displayName     String?   @map("display_name")
  postsJson       String?   @map("posts_json") @db.Text
  embedding       String?   @map("embedding") @db.Text
  lastSyncedAt    DateTime? @map("last_synced_at")
  postCount       Int?      @map("post_count")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("linkedin_profiles")
}

model DailyIdea {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  title           String
  description     String?
  sourceArticleId String?   @map("source_article_id")
  sourceArticle   Article?  @relation(fields: [sourceArticleId], references: [id], onDelete: SetNull)
  status          String    @default("draft") // "draft" | "used" | "archived"
  createdAt       DateTime  @default(now()) @map("created_at")
  generatedPosts  GeneratedPost[]

  @@map("daily_ideas")
}

model GeneratedPost {
  id                  String    @id @default(uuid())
  ideaId              String?   @map("idea_id")
  idea                DailyIdea? @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  draftContent        String    @map("draft_content") @db.Text
  finalContent        String?   @map("final_content") @db.Text
  status              String    @default("draft") // "draft" | "approved" | "posted"
  versions            String?   @map("versions") @db.Text
  currentVersionIndex Int?      @map("current_version_index")
  linkedInPostId      String?   @map("linkedin_post_id")
  publishedToLinkedInAt DateTime? @map("published_to_linkedin_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@map("generated_posts")
}
